{
  "name": "backend",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx src/server.js",
    "dev:watch": "tsx watch src/server.js",
    "start": "node src/server.js",
    "build": "node --check src/server.js",
    "render:build": "prisma generate && prisma db push && npm run seed",
    "lint": "node --check src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma db push",
    "prisma:push": "prisma db push",
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "prisma": "^6.1.0",
    "tsx": "^4.19.2"
  }
}
